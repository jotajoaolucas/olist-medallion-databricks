{
  "datasets": [
    {
      "name": "0bb333e3",
      "displayName": "satisfação_x_entrega",
      "queryLines": [
        "SELECT status_entrega, nota_media, qtd_avaliacoes\r\n",
        "FROM olist_project.gold.satisfacao_entrega;"
      ]
    },
    {
      "name": "7a61853f",
      "displayName": "top_vendedores",
      "queryLines": [
        "SELECT seller_id, seller_state, receita_total, qtd_pedidos, nota_media\r\n",
        "FROM olist_project.gold.ranking_vendedores\r\n",
        "ORDER BY receita_total DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "43415db5",
      "displayName": "performance_de_entrega",
      "queryLines": [
        "SELECT mes, tempo_medio_entrega_dias, pct_entregas_no_prazo, pct_entregas_atrasadas\r\n",
        "FROM olist_project.gold.performance_entrega_mensal\r\n",
        "ORDER BY mes;"
      ]
    },
    {
      "name": "b322635f",
      "displayName": "receita_por_estado",
      "queryLines": [
        "SELECT estado, receita_total, qtd_pedidos, ticket_medio\r\n",
        "FROM olist_project.gold.receita_por_estado\r\n",
        "ORDER BY receita_total DESC;"
      ]
    },
    {
      "name": "9fa781d1",
      "displayName": "receita_mensal",
      "queryLines": [
        "SELECT \r\n",
        "    mes, \r\n",
        "    receita_produtos, \r\n",
        "    receita_frete, \r\n",
        "    qtd_pedidos, \r\n",
        "    variacao_pct\r\n",
        "FROM olist_project.gold.receita_mensal\r\n",
        "ORDER BY mes;"
      ]
    },
    {
      "name": "e88a0f74",
      "displayName": "receita_mes_atual",
      "queryLines": [
        "SELECT \r\n",
        "    mes,\r\n",
        "    receita_produtos,\r\n",
        "    variacao_pct,\r\n",
        "    qtd_pedidos\r\n",
        "FROM olist_project.gold.receita_mensal where mes not in ('2018-09')\r\n",
        "ORDER BY mes DESC\r\n",
        "LIMIT 1; "
      ]
    }
  ],
